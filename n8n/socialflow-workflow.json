    {
      "parameters": {
        "jsCode": "const output = $json.output;\n\n// Split using \"Hashtags:\" keyword\nconst parts = output.split(\"Hashtags:\");\n\nconst captionPart = parts[0].replace(\"Caption:\", \"\").trim();\nconst hashtagsPart = parts[1].trim();\n\nreturn [\n  {\n    json: {\n      caption: captionPart,\n      hashtags: hashtagsPart\n    }\n  }\n];"
